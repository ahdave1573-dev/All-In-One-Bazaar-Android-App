<?xml version="1.0" encoding="utf-8"?>
<!--
    item_onboarding_page.xml
    Place in: res/layout/
    Used by OnboardingAdapter for each ViewPager2 page.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingBottom="24dp"
    android:background="@color/ocean_background">

    <!-- Illustration Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/ocean_card_illustration">

        <ImageView
            android:id="@+id/imgOnboarding"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"/>

    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/txtOnboardingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/ocean_dark"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:layout_marginBottom="14dp"/>

    <!-- Description -->
    <TextView
        android:id="@+id/txtOnboardingDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/ocean_secondary"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:fontFamily="@font/poppins_regular"/>

</LinearLayout>
