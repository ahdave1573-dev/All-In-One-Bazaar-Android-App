<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C70039"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F9EAE7"
        android:orientation="vertical">

        <!-- Toolbar Section -->
        <RelativeLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:paddingHorizontal="18dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="#FADCD9"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#C70039" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Product Reviews"
                android:textColor="#900C3F"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#F0D3CE" />

        <!-- Main Content Area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Empty State Layout -->
            <LinearLayout
                android:id="@+id/layoutEmptyReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#B58B84" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No Reviews Yet Star ⭐"
                    android:textColor="#900C3F"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RecyclerView for Reviews List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAdminReviews"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp"
                android:scrollbars="none" />

            <!-- Loading ProgressBar -->
            <ProgressBar
                android:id="@+id/progressBarReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminateTint="#C70039" />
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>