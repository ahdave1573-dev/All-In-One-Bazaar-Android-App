<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FCF2F0"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="#EBBFB8"
    app:strokeWidth="1.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon Box -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardIcon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardBackgroundColor="#F9EAE7"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📦"
                android:textSize="24sp" />
        </androidx.cardview.widget.CardView>

        <!-- Order ID & Details -->
        <TextView
            android:id="@+id/txtAdminOrderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textColor="#4A0E17"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintTop_toTopOf="@id/cardIcon"
            tools:text="Order ID: 12345" />

        <TextView
            android:id="@+id/txtAdminOrderAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#900C3F"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/txtAdminOrderId"
            app:layout_constraintTop_toBottomOf="@id/txtAdminOrderId"
            tools:text="Total: ₹ 500" />

        <!-- Status Badge -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F0D3CE"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardIcon">

            <TextView
                android:id="@+id/txtAdminOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="#900C3F"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Pending" />
        </androidx.cardview.widget.CardView>

        <!-- Update Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeStatus"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="UPDATE"
            android:textColor="#F9EAE7"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#900C3F"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtAdminOrderAmount" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>