<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@drawable/bg_drawer_header_ocean"
    android:gravity="center" android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <androidx.cardview.widget.CardView
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal" app:cardBackgroundColor="@color/ocean_surface"
        app:cardCornerRadius="38dp"
        app:cardElevation="6dp">

        <ImageView
            android:id="@+id/imgNavProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_myplaces" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtNavName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center" android:text="Bazaar User"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <TextView
        android:id="@+id/txtNavEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center" android:text="user@bazaar.com"
        android:textColor="@color/ocean_light"
        android:textSize="14sp" />

</LinearLayout>