<?xml version="1.0" encoding="utf-8"?>
<!--
    item_user_category.xml
    Place in: res/layout/
    Ocean Calm category grid item — blue card + white outer ring
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Outer white ring -->
    <androidx.cardview.widget.CardView
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardBackgroundColor="@color/ocean_white"
        app:cardCornerRadius="40dp"
        app:cardElevation="2dp">

        <!-- Inner ocean_background circle -->
        <androidx.cardview.widget.CardView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/ocean_background"
            app:cardCornerRadius="34dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgCatIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"/>

        </androidx.cardview.widget.CardView>
    </androidx.cardview.widget.CardView>

    <!-- Category name -->
    <TextView
        android:id="@+id/txtCatName"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Category"
        android:textColor="@color/ocean_text_primary"
        android:fontFamily="@font/poppins_medium"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:maxLines="2"
        android:ellipsize="end"/>

</LinearLayout>
