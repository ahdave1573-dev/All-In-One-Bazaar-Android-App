<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ocean_background"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp"
        android:background="@drawable/bg_circle_ocean_mid"
        android:alpha="0.35"/>

    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="140dp"
        android:layout_marginStart="-40dp"
        android:background="@drawable/bg_circle_ocean_mid"
        android:backgroundTint="@color/ocean_cta"
        android:alpha="0.12"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="45dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/ocean_primary">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shopping_bag"
                        app:tint="@color/ocean_background"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bazaar."
                    android:textColor="@color/ocean_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome"
                android:textColor="@color/ocean_text_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="0.9"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textColor="@color/ocean_cta"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue your shopping"
                android:textColor="@color/ocean_text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_login_card"
            android:paddingHorizontal="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="@color/ocean_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_field_ocean"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/ocean_secondary"/>

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="name@example.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/ocean_text_primary"
                    android:textColorHint="@color/ocean_hint"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="@color/ocean_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_field_ocean"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="@color/ocean_secondary"/>

                <EditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter your password"
                    android:inputType="textPassword"
                    android:paddingStart="48dp"
                    android:paddingEnd="52dp"
                    android:textColor="@color/ocean_text_primary"
                    android:textColorHint="@color/ocean_hint"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"/>

                <ImageView
                    android:id="@+id/imgTogglePassword"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/ocean_hint"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="@color/ocean_cta"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:layout_gravity="end"
                android:layout_marginBottom="24dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_login_ocean"
                android:stateListAnimator="@null"
                android:text="SIGN IN"
                android:textColor="@color/ocean_background"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ocean_divider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  or continue with  "
                    android:textColor="@color/ocean_text_secondary"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ocean_divider"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnGoogleLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_google_ocean"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/fui_ic_goog_icon_color_24dp"
                        app:tintMode="src_in" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continue with Google"
                        android:textColor="@color/ocean_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_medium"/>
                </LinearLayout>
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New to Bazaar? "
                    android:textColor="@color/ocean_text_secondary"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account →"
                    android:textColor="@color/ocean_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>