<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#F9EAE7"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 🛠️ અહીં ટેક્સ્ટ બદલીને "Loading..." કરી દીધું છે -->
            <TextView
                android:id="@+id/txtReviewUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Loading..."
                android:textColor="#900C3F"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RatingBar
                android:id="@+id/rowRatingBar"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:isIndicator="true"
                android:numStars="5"
                android:progressTint="#C70039" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtReviewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="No text review provided."
            android:textColor="#B58B84"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>