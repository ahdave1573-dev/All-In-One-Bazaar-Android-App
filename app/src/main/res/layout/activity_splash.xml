<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_ocean">

    <!-- Decorative circle — top right -->
    <View
        android:id="@+id/circleTop"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.35"
        android:background="@drawable/bg_circle_ocean_mid"
        android:layout_marginEnd="-48dp"
        android:layout_marginTop="-48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Decorative circle — bottom left -->
    <View
        android:id="@+id/circleBottom"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:alpha="0.15"
        android:background="@drawable/bg_circle_ocean_dark"
        android:layout_marginStart="-32dp"
        android:layout_marginBottom="-32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Center content group -->
    <LinearLayout
        android:id="@+id/centerGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo card: white circle with shopping bag icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/logoCard"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            app:cardCornerRadius="44dp"
            app:cardBackgroundColor="@color/ocean_white"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shopping_bag"
                android:scaleType="centerInside"
                app:tint="@color/ocean_primary" />

        </androidx.cardview.widget.CardView>

        <!-- App name -->
        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/ocean_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.02" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/txtTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_tagline"
            android:textColor="@color/ocean_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Bottom loader group -->
    <LinearLayout
        android:id="@+id/bottomGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Spinning ring loader -->
        <ProgressBar
            android:id="@+id/splashProgress"
            style="?android:attr/progressBarStyle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:indeterminateTint="@color/ocean_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textColor="@color/ocean_secondary"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.05" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
