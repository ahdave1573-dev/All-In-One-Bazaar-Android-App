<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ocean_background"
    android:fitsSystemWindows="true"
    tools:context=".ui.auth.RegisterActivity">

    <View
        android:id="@+id/topBlob"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp"
        android:background="@drawable/bg_circle_ocean_mid"
        android:alpha="0.35"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="120dp"
        android:layout_marginStart="-40dp"
        android:background="@drawable/bg_circle_ocean_mid"
        android:backgroundTint="@color/ocean_cta"
        android:alpha="0.12"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/ocean_primary">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/ocean_background"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Bazaar."
            android:textColor="@color/ocean_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.02"/>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/headlineLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create"
            android:textColor="@color/ocean_text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"
            android:lineSpacingMultiplier="0.9"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account"
            android:textColor="@color/ocean_cta"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/ocean_white"
        app:layout_constraintTop_toBottomOf="@id/headlineLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="26dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAvatar"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    app:cardCornerRadius="43dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/ocean_background"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="22dp"
                        app:tint="@color/ocean_secondary"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnUploadPhoto"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/ocean_cta"
                    app:layout_constraintBottom_toBottomOf="@id/cardAvatar"
                    app:layout_constraintEnd_toEndOf="@id/cardAvatar"
                    android:layout_marginBottom="2dp"
                    android:layout_marginEnd="2dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="@color/ocean_dark"/>
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/ocean_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_field_ocean"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="@color/ocean_secondary"/>

                <EditText
                    android:id="@+id/edtRegName"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter your full name"
                    android:textColorHint="@color/ocean_hint"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/ocean_text_primary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="@color/ocean_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_field_ocean"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/ocean_secondary"/>

                <EditText
                    android:id="@+id/edtRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="example@email.com"
                    android:textColorHint="@color/ocean_hint"
                    android:inputType="textEmailAddress"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/ocean_text_primary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="@color/ocean_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_field_ocean"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="@color/ocean_secondary"/>

                <EditText
                    android:id="@+id/edtRegPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Min. 6 characters"
                    android:textColorHint="@color/ocean_hint"
                    android:inputType="textPassword"
                    android:paddingStart="48dp"
                    android:paddingEnd="52dp"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/ocean_text_primary"/>

                <ImageView
                    android:id="@+id/imgTogglePasswordReg"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/ocean_hint"/>
            </FrameLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_login_ocean"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:text="CREATE ACCOUNT"
                android:textColor="@color/ocean_background"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.08"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="@color/ocean_text_secondary"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In →"
                    android:textColor="@color/ocean_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>