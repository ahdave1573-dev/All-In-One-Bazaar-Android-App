        android:fillColor="#1A56C4"
        android:fillAlpha="0.5"/>

    <!-- Shield main body -->
    <path
        android:pathData="M55,20 L84,34 L84,52 Q84,70 55,84 Q26,70 26,52 L26,34 Z"
        android:fillColor="#1A56C4"/>

    <!-- Shield inner highlight arc (top) -->
    <path
        android:pathData="M55,26 L78,38 L78,48"
        android:strokeColor="#E8F4FD"
        android:strokeWidth="2"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Lock body -->
