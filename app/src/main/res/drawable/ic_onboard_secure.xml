        android:strokeColor="#E8F4FD"
        android:strokeWidth="2"
        android:pathData="M80,12 a14,14 0 1,0 0,28 a14,14 0 1,0 0,-28"/>

    <!-- Checkmark tick -->
    <path
        android:pathData="M73,26 L78,31 L88,20"
        android:strokeColor="#633806"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- SSL label tag -->
    <path
        android:pathData="M28,32 L46,32 Q50,32 50,36 L50,42 Q50,46 46,46 L28,46 Q24,46 24,42 L24,36 Q24,32 28,32 Z"
