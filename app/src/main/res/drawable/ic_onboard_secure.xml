        android:strokeColor="#E8F4FD"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Lock shackle inner (cutout effect) -->
    <path
        android:pathData="M47,56 Q47,45 55,45 Q63,45 63,56"
        android:strokeColor="#1A56C4"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Keyhole circle (Converted to path) -->
    <path
        android:fillColor="#1A56C4"
        android:pathData="M55,60 a5,5 0 1,0 0,10 a5,5 0 1,0 0,-10"/>

    <!-- Keyhole slot -->
    <path
        android:pathData="M53,68 L57,68 L57,74 L53,74 Z"
        android:fillColor="#1A56C4"/>

    <!-- Checkmark badge circle (Converted to path) -->
    <path
        android:fillColor="#F5A623"
        android:pathData="M80,12 a14,14 0 1,0 0,28 a14,14 0 1,0 0,-28"/>

    <!-- Checkmark badge circle border (Converted to path) -->
