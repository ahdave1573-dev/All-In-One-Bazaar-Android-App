    <path android:fillColor="#1A56C4" android:pathData="M30,37 a2,2 0 1,0 0,4 a2,2 0 1,0 0,-4"/>
    <path android:fillColor="#1A56C4" android:pathData="M37,37 a2,2 0 1,0 0,4 a2,2 0 1,0 0,-4"/>
    <path android:fillColor="#1A56C4" android:pathData="M44,37 a2,2 0 1,0 0,4 a2,2 0 1,0 0,-4"/>

