<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_onboard_secure.xml
    Place in: res/drawable/
    Size: 110x110dp
    Theme: Ocean Calm — layered shield with padlock and amber checkmark badge
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="110dp"
    android:height="110dp"
    android:viewportWidth="110"
    android:viewportHeight="110">

    <!-- Shield outer glow layer -->
    <path
        android:pathData="M55,10 L92,26 L92,52 Q92,78 55,96 Q18,78 18,52 L18,26 Z"
