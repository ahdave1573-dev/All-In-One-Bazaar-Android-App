<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_btn_google_ocean.xml
    Place in: res/drawable/
    Google Sign-In button — ocean_background fill + ocean_surface border + 12dp radius
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ocean_background"/>
    <stroke android:width="1dp" android:color="@color/ocean_surface"/>
    <corners android:radius="12dp"/>
</shape>
