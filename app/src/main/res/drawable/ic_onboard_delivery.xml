    <path
        android:pathData="M78,62 L78,76"
        android:strokeColor="#E8F4FD"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.4"/>

    <!-- Wheel left (cargo) converted to path -->
    <path
        android:fillColor="#0C3A8A"
        android:pathData="M26,68 a10,10 0 1,0 0,20 a10,10 0 1,0 0,-20"/>
    <path
        android:fillColor="#E8F4FD"
        android:pathData="M26,72 a6,6 0 1,0 0,12 a6,6 0 1,0 0,-12"/>
    <path
        android:fillColor="#1A56C4"
        android:pathData="M26,75 a3,3 0 1,0 0,6 a3,3 0 1,0 0,-6"/>

    <!-- Wheel right (cab) converted to path -->
    <path
        android:fillColor="#0C3A8A"
        android:pathData="M84,68 a10,10 0 1,0 0,20 a10,10 0 1,0 0,-20"/>
    <path
        android:fillColor="#E8F4FD"
        android:pathData="M84,72 a6,6 0 1,0 0,12 a6,6 0 1,0 0,-12"/>
    <path
        android:fillColor="#1A56C4"
        android:pathData="M84,75 a3,3 0 1,0 0,6 a3,3 0 1,0 0,-6"/>

    <!-- Speed lines (amber) -->
    <path
        android:pathData="M2,50 L16,50"
        android:strokeColor="#F5A623"
        android:strokeWidth="3"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M4,58 L14,58"
        android:strokeColor="#F5A623"
        android:strokeWidth="3"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M2,66 L12,66"
        android:strokeColor="#F5A623"
        android:strokeWidth="3"
        android:strokeLineCap="round"/>

    <!-- Lightning badge circle converted to path -->
    <path
        android:fillColor="#F5A623"
        android:pathData="M90,14 a14,14 0 1,0 0,28 a14,14 0 1,0 0,-28"/>
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8F4FD"
        android:strokeWidth="2"
        android:pathData="M90,14 a14,14 0 1,0 0,28 a14,14 0 1,0 0,-28"/>

    <!-- Lightning bolt inside badge -->
    <path
        android:pathData="M93,18 L87,28 L91,28 L87,38 L97,26 L92,26 Z"
        android:fillColor="#633806"/>

