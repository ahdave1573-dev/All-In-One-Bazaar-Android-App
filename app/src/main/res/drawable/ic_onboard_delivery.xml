        android:fillColor="#1A56C4"/>

    <!-- Cargo box window / logo area -->
    <path
        android:pathData="M16,48 L58,48 L58,64 L16,64 Z"
        android:fillColor="#E8F4FD"
        android:fillAlpha="0.15"/>

    <!-- Cargo box horizontal stripe -->
    <path
        android:pathData="M8,66 L66,66 L66,72 L8,72 Z"
        android:fillColor="#0C3A8A"
        android:fillAlpha="0.3"/>

    <!-- Truck cab -->
