<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_onboard_delivery.xml
    Place in: res/drawable/
    Size: 110x110dp
    Theme: Ocean Calm — delivery truck with speed lines and amber lightning badge
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="110dp"
    android:height="110dp"
    android:viewportWidth="110"
    android:viewportHeight="110">

    <!-- Road / ground line -->
    <path
        android:pathData="M8,80 L102,80"
        android:strokeColor="#A8D5F0"
        android:strokeWidth="3"
        android:strokeLineCap="round"/>

    <!-- Truck cargo box shadow -->
    <path
        android:pathData="M14,44 L60,44 L60,76 L14,76 Z"
        android:fillColor="#A8D5F0"
        android:fillAlpha="0.35"/>

    <!-- Truck cargo box main -->
    <path
