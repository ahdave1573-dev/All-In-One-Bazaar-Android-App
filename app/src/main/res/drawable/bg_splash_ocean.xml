<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_splash_ocean.xml
    Place in: res/drawable/

    Diagonal gradient: light sky → medium blue
    Angle 160° = top-left bright, bottom-right slightly deeper
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:type="linear"
        android:angle="160"
        android:startColor="#E8F4FD"
        android:centerColor="#C6E4F8"
        android:endColor="#A8D5F0" />

</shape>
