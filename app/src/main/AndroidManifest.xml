<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.all_in_one_bazaar">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" /> <!-- Android 13+ માટે -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.all_in_one_bazaar"
        tools:targetApi="31">
        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.reports.AdminReviewsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.client.features.NotificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.admin.AdminReportsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.category.ManageCategoriesActivity"
            android:exported="false"
            android:label="Manage Categories"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" />
        <activity
            android:name=".ui.admin.AdminUsersActivity"
            android:exported="false" />
        <activity
            android:name=".ui.client.product.RateProductActivity"
            android:exported="false"
            android:label="Rate Product"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.admin.dashboard.AdminDashboardActivity"
            android:exported="false"
            android:label="Admin Dashboard" />
        <activity
            android:name=".ui.admin.product.AddProductActivity"
            android:exported="false"
            android:label="Add Product"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" />
        <activity
            android:name=".ui.admin.order.AdminOrdersActivity"
            android:exported="false"
            android:label="Manage Orders"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" />
        <activity
            android:name=".ui.client.profile.EditProfileActivity"
            android:exported="false"
            android:label="Edit Profile"
            android:parentActivityName=".ui.client.profile.ProfileActivity"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.features.WishlistActivity"
            android:exported="false"
            android:label="My Wishlist"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.order.MyOrdersActivity"
            android:exported="false"
            android:label="My Orders"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.product.ProductListActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.profile.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" /> <!-- ✅ Splash Screen — App Entry Point -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.all_in_one_bazaar.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.auth.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.home.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.product.ProductDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.cart_checkout.CartActivity"
            android:exported="false"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.category.CategoryProductsActivity"
            android:exported="false"
            android:label="Browse Categories"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.cart_checkout.CheckoutActivity"
            android:exported="false"
            android:label="Checkout"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.cart_checkout.OrderSuccessActivity"
            android:exported="false"
            android:label="Order Success"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.client.features.SearchActivity"
            android:exported="false"
            android:label="Search Products"
            android:theme="@style/Theme.Client.OceanCalm" />
        <activity
            android:name=".ui.admin.product.ManageProductsActivity"
            android:exported="false"
            android:label="Manage Products"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" />
        <activity
            android:name=".ui.admin.product.EditProductActivity"
            android:exported="false"
            android:label="Edit Product"
            android:parentActivityName=".ui.admin.product.ManageProductsActivity" />
        <activity
            android:name=".ui.admin.users.ManageUsersActivity"
            android:exported="false"
            android:label="Registered Users"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" />
        <activity
            android:name=".ui.admin.reports.SalesReportsActivity"
            android:exported="false"
            android:label="Sales Reports"
            android:parentActivityName=".ui.admin.dashboard.AdminDashboardActivity" /> <!-- 🔥 સર્વિસ પાથ સુધારેલો છે -->
        <service
            android:name=".Service.MyMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>